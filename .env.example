# Core
DATABASE_URL="file:./dev.db"
ALLOWED_ORIGIN="http://localhost:3000"

# Admin security
ADMIN_API_TOKEN="change-me"
ADMIN_SESSION_SECRET="change-me-to-a-long-random-secret"
NEXT_PUBLIC_ENABLE_MODERATION_PANEL="false"

# Suggestions lead email (optional)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Local LLM scoring (optional)
OLLAMA_URL="http://127.0.0.1:11434/api/generate"
OLLAMA_MODEL="mistral"

# Existing placeholders
TRANSLATION_PROVIDER="local"
OPENAI_API_KEY=""

# Distributed rate limit (optional, recommended in production)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Production smoke/deploy helpers
PRODUCTION_BASE_URL=""
VERCEL_GIT_COMMIT_SHA=""

# Suggestion validation timeouts
SUGGESTION_WEB_TIMEOUT_MS="2500"
SUGGESTION_LLM_TIMEOUT_MS="3000"
